# Ejemplo de variables de entorno para producción (Vercel / Hostinger)
# Copia este archivo a .env.production localmente si lo necesitas,
# o configura las mismas variables en el dashboard de Vercel/Hostinger.

# Cadena de conexión MySQL proporcionada por Hostinger.
# Formato: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://user:password@db123.hostinger.com:3306/seguranet"

# JWT y cifrado — reemplazar por valores seguros
JWT_SECRET=REEMPLAZAR_CON_UN_SECRET_LARGO
JWT_EXPIRY=3600
AES_MASTER_KEY=REEMPLAZAR_64_CHARS_HEX
HMAC_SIGNING_KEY=REEMPLAZAR_64_CHARS_HEX
ARGON2_PEPPER=REEMPLAZAR_PEPER

# Storage en producción: no usar almacenamiento local en Vercel
UPLOAD_DIR=/tmp/uploads  # temporal: usar S3/Supabase Storage/Cloudflare R2 en producción
MAX_FILE_SIZE_MB=50

# Otros (bootstrap, rate limits)
SESSION_COOKIE_NAME=seguranet_session
SESSION_COOKIE_MAX_AGE=3600
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_BLOCK_MINUTES=30
RATE_LIMIT_API_PER_MINUTE=100

# Opcionales
ENABLE_RENIEC_VALIDATION=false
GOOGLE_GENAI_API_KEY=
