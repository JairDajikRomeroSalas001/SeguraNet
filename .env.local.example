# Ejemplo local — NO commitees con valores reales
# Copia a .env.local y rellena con tus secretos reales para desarrollo

# Conexion MySQL de Hostinger (ejemplo):
# mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE"

JWT_SECRET=REPLACE_WITH_A_RANDOM_HEX_64
JWT_EXPIRY=3600

AES_MASTER_KEY=REPLACE_WITH_64_CHARS_HEX
HMAC_SIGNING_KEY=REPLACE_WITH_64_CHARS_HEX
ARGON2_PEPPER=replace_with_pepper_value

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

SESSION_COOKIE_NAME=seguranet_session
SESSION_COOKIE_MAX_AGE=3600

RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_BLOCK_MINUTES=30
RATE_LIMIT_API_PER_MINUTE=100

BOOTSTRAP_ADMIN_USERNAME=admin1
BOOTSTRAP_ADMIN_PASSWORD=ChangeMeImmediately!2026
BOOTSTRAP_ADMIN_FULLNAME=MARCO ANTONIO CASAS SOLIS
BOOTSTRAP_ADMIN_DNI=98543265

ENABLE_RENIEC_VALIDATION=false
RENIEC_API_URL=
RENIEC_API_KEY=

GOOGLE_GENAI_API_KEY=
